{
  "name": "velora-monorepo",
  "version": "1.0.0",
  "description": "Premium Glassmorphic E-Commerce Platform",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:full": "npm run install:all && npm run dev",
    "seed": "cd backend && node data/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}